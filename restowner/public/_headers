# Cloudflare Pages headers.
#
# index.html and other root HTML routes MUST NOT be cached by the
# browser. The bundle filenames (index-<hash>.js) are content-hashed,
# so the JS/CSS can cache forever — but the HTML that points at them
# has to be re-fetched every visit, otherwise Safari/iOS will keep a
# stale tab running yesterday's bundle (and yesterday's bugs) for
# hours after a deploy.

/
  Cache-Control: no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/index.html
  Cache-Control: no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Hashed assets — fingerprinted at build time, safe to cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
